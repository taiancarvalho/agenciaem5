---
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — em5 Painel</title>
  <style>
    :root {
      --bg: #0a0e1a;
      --bg-card: #131826;
      --bg-card-hover: #1a2032;
      --border: #232838;
      --text: #e8edf5;
      --text-dim: #8a93a8;
      --accent: #5b8dee;
      --critico: #ef4444;
      --alto: #f97316;
      --medio: #eab308;
      --baixo: #22c55e;
      --ok: #22c55e;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.5;
      min-height: 100vh;
    }
    .container { max-width: 1400px; margin: 0 auto; padding: 2rem; }
    header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding-bottom: 1.5rem;
      border-bottom: 1px solid var(--border);
      margin-bottom: 2rem;
    }
    h1 { font-size: 1.5rem; font-weight: 700; }
    h1 .tag { color: var(--text-dim); font-weight: 400; font-size: 0.95rem; }
    .tagline { color: var(--text-dim); font-size: 0.85rem; margin-top: 0.25rem; }
    .badge {
      display: inline-block;
      padding: 0.25rem 0.6rem;
      border-radius: 999px;
      font-size: 0.75rem;
      font-weight: 600;
    }
    .badge.critico { background: rgba(239, 68, 68, 0.15); color: var(--critico); }
    .badge.alto { background: rgba(249, 115, 22, 0.15); color: var(--alto); }
    .badge.medio { background: rgba(234, 179, 8, 0.15); color: var(--medio); }
    .badge.baixo { background: rgba(34, 197, 94, 0.15); color: var(--baixo); }
    .badge.ok { background: rgba(34, 197, 94, 0.15); color: var(--ok); }
    .kpis {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 1rem;
      margin-bottom: 2rem;
    }
    .kpi {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1.25rem;
    }
    .kpi-label { color: var(--text-dim); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; }
    .kpi-value { font-size: 1.75rem; font-weight: 700; margin-top: 0.25rem; }
    .clients-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: 1rem;
    }
    .client-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1.25rem;
      transition: background 0.15s, transform 0.15s;
    }
    .client-card:hover { background: var(--bg-card-hover); transform: translateY(-2px); }
    .client-card.severity-critico { border-left: 4px solid var(--critico); }
    .client-card.severity-alto { border-left: 4px solid var(--alto); }
    .client-card.severity-medio { border-left: 4px solid var(--medio); }
    .client-name { font-size: 1.1rem; font-weight: 600; margin-bottom: 0.25rem; }
    .client-nicho { color: var(--text-dim); font-size: 0.85rem; margin-bottom: 1rem; }
    .client-metrics {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.5rem;
      margin-bottom: 1rem;
    }
    .metric-label { font-size: 0.7rem; color: var(--text-dim); text-transform: uppercase; }
    .metric-value { font-size: 1rem; font-weight: 600; }
    .client-next { font-size: 0.85rem; color: var(--text); padding-top: 0.75rem; border-top: 1px solid var(--border); }
    .alert {
      background: rgba(239, 68, 68, 0.08);
      border: 1px solid rgba(239, 68, 68, 0.2);
      padding: 0.75rem;
      border-radius: 8px;
      font-size: 0.85rem;
      margin-bottom: 0.75rem;
    }
    .footer {
      margin-top: 3rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--border);
      color: var(--text-dim);
      font-size: 0.8rem;
      text-align: center;
    }
    a { color: var(--accent); text-decoration: none; }
    a:hover { text-decoration: underline; }
  </style>
</head>
<body>
  <div class="container">
    <header>
      <div>
        <h1>em5 <span class="tag">painel</span></h1>
        <div class="tagline">Agência em Cinco minutos.</div>
      </div>
      <div>
        <span class="badge ok">v1.2.0</span>
      </div>
    </header>
    <slot />
    <div class="footer">
      <p>em5 painel — gerado estaticamente. Filesystem-first (Art. I). <a href="https://github.com/taiancarvalho/agenciaem5">github</a></p>
    </div>
  </div>
</body>
</html>
