# ============================================
# em5 — Environment Configuration
# ============================================
# Copie este arquivo pra .env e preencha valores reais
# NUNCA commite .env com credentials reais
# ============================================

# --------------------------------------------
# Composio (Gateway Default — Art. IX)
# --------------------------------------------
# Pega em https://app.composio.dev/
# Toolsets habilitados em .claude/settings.json:
#   meta_ads, google_analytics, googlesheets, gmail, slack,
#   whatsapp_business, googledrive
COMPOSIO_API_KEY=

# --------------------------------------------
# Asaas MCP (Exceção Art. IX — financeiro BR)
# --------------------------------------------
# Documentado em .em5/integracoes/excecoes.yaml
# Aprovado @ceo em 2026-05-16
# Pega em https://www.asaas.com/ (sandbox ou prod)
# Tipo: access_token format $aact_xxx
ASAAS_TOKEN=

# Sandbox vs Prod (default: false = prod)
ASAAS_SANDBOX=false

# --------------------------------------------
# WhatsApp (provider: composio | waha)
# --------------------------------------------
# Se provider=composio → vai pelo COMPOSIO_API_KEY
# Se provider=waha (selfhosted) → URL local
WAHA_URL=http://localhost:3000
WAHA_API_KEY=

# --------------------------------------------
# Anthropic API (opcional — fora do Claude Code)
# --------------------------------------------
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --------------------------------------------
# Context7 (lookup docs)
# --------------------------------------------
# Geralmente free, sem key obrigatória
CONTEXT7_API_KEY=

# --------------------------------------------
# GitHub (releases + auto-update Electron)
# --------------------------------------------
GITHUB_TOKEN=

# --------------------------------------------
# em5 Config
# --------------------------------------------
NODE_ENV=development
EM5_VERSION=1.3.0

# Owner pra handoff humano (@whats Onda)
EM5_OWNER_PHONE=
EM5_OWNER_EMAIL=

# --------------------------------------------
# Painel (porta dev)
# --------------------------------------------
PAINEL_PORT=4321
