# ============================================
# em5 — gitignore
# ============================================

# Environment & Secrets
.env
.env.local
.env.*.local
*.key
*.pem
*-secrets.yaml
**/financeiro/secrets.yaml
**/setup-tecnico/credenciais.yaml

# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
*.log
logs/

# Painel (Astro)
painel/dist/
painel/.astro/

# Desktop (Electron)
desktop/dist-app/
desktop/node_modules/

# em5 local (não versionar)
.em5/clientes/*/temp/
.em5/_dia/
.em5/_fin/
.em5/construcao/*/build-log.md
*.backup
.em5.v*.backup/

# IDE & OS
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# Claude Code local
.claude/settings.local.json
.claude/projects/
